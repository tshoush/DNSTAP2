# Prometheus config — generated by scripts/render_prometheus_config.py
# Do not edit by hand; regenerate from config.toml + this template.

global:
  scrape_interval: $scrape_interval
  evaluation_interval: $scrape_interval
  external_labels:
    environment: lab
    monitor: dnstap2

scrape_configs:
  - job_name: vector_dnstap
    metrics_path: /metrics
    static_configs:
      - targets: ["$vector_metrics_target"]
        labels:
          source: vector

  # Optional alternative receiver: DNS-collector (dmachard), installed alongside
  # Vector by scripts/install_dnscollector_receiver.sh on :9599 (dnscollector_*
  # metrics). Harmless if not installed — Prometheus simply shows this job down.
  - job_name: dnscollector
    metrics_path: /metrics
    static_configs:
      - targets: ["$dnscollector_metrics_target"]
        labels:
          source: dnscollector

  - job_name: prometheus_self
    static_configs:
      - targets: ["localhost:9090"]
