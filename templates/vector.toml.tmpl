# Vector config — generated by scripts/render_vector_config.py
# Do not edit by hand; regenerate from config.toml + this template.

data_dir = "$data_dir"
# Render VRL timestamps (the NIOS-style syslog lines) in host-local time, like
# NIOS itself does. Without this they render UTC with no TZ marker and Splunk
# places the events hours in the future.
timezone = "local"

# ─────────────────────────────────────────────────────────────────────────────
# Source: receive dnstap frames from InfoBlox.
# Vector's `dnstap` source speaks Frame Streams natively and decodes the
# protobuf payload for us.
# ─────────────────────────────────────────────────────────────────────────────
[sources.dnstap_in]
type = "dnstap"
mode = "tcp"
address = "$listen_host:$listen_port"
# Tune for the receiver host:
max_frame_length = 102400

# ─────────────────────────────────────────────────────────────────────────────
# Source: Vector's own operational metrics. Feeding these into the Prometheus
# exporter guarantees /metrics always returns content (even before any dnstap
# events arrive) and surfaces decode/throughput/error counters for the pipeline.
# ─────────────────────────────────────────────────────────────────────────────
[sources.internal_metrics]
type = "internal_metrics"

# ─────────────────────────────────────────────────────────────────────────────
# Transform: enrich every event with static labels and normalize fields.
# ─────────────────────────────────────────────────────────────────────────────
[transforms.dnstap_enriched]
type = "remap"
inputs = ["dnstap_in"]
source = '''
# Stable labels so downstream consumers can identify this stream.
.environment = "lab"
.dns_vendor  = "infoblox"
.collector   = "vector"

# Promote commonly-queried fields to predictable top-level names.
# NIOS dnstap as decoded by Vector's dnstap source puts the DNS question under
# .requestData (ClientQuery) or .responseData (ClientResponse) — NOT .message.*.
# Path/array access is INFALLIBLE in VRL (missing -> null), so coalesce with
# if/null. Do NOT use `?? null` on these: VRL rejects error-coalescing on an
# infallible expression (error E651) and Vector will refuse to start.
.qname = .responseData.question[0].domainName
if .qname == null { .qname = .requestData.question[0].domainName }
.qtype = .responseData.question[0].questionType
if .qtype == null { .qtype = .requestData.question[0].questionType }
.rcode  = .responseData.rcodeName       # null on ClientQuery events
.client = .sourceAddress                # real client IP
'''

# ─────────────────────────────────────────────────────────────────────────────
# Transform: render each event as the syslog line NIOS itself emits when
# "DNS query logging / response logging" is enabled, so downstream parsers
# built for InfoBlox syslog (e.g. the Splunk Add-on for Infoblox,
# sourcetype infoblox:dns) keep working unchanged:
#   query:    <ts> <member> named[<id>]: client <ip>#<port> (<qname>): query: <qname> IN <type> + (<server-ip>)
#   response: <ts> <member> named[<id>]: client <ip>#<port> (<qname>): UDP: query: <qname> IN <type> response: NOERROR +A <rr>; <rr>;
# <member> comes from the dnstap identity (serverId); named[<id>] carries the
# DNS message id (dnstap has no daemon pid). Flags: + recursion desired,
# A authoritative answer, T truncated, D DNSSEC-validated (AD bit).
# ─────────────────────────────────────────────────────────────────────────────
[transforms.dnstap_nios_syslog]
type = "remap"
inputs = ["dnstap_enriched"]
source = '''
# Vector 0.39 marks format_timestamp fallible even with now(), so `??` with a
# format_timestamp fallback is E103 there — capture the error instead.
# timezone: "local" renders member-local time like NIOS itself; without it the
# line is UTC with no TZ marker and Splunk shifts events into the future.
fmt = "%b %e %H:%M:%S"
syslog_ts, ts_err = format_timestamp(.timestamp, fmt, timezone: "local")
if ts_err != null { syslog_ts = format_timestamp!(now(), fmt, timezone: "local") }
host = to_string(.serverId) ?? ""
if host == "" { host = "infoblox" }
client = to_string(.sourceAddress) ?? "0.0.0.0"
cport  = to_string(.sourcePort) ?? "0"
server = to_string(.responseAddress) ?? ""
proto  = upcase(to_string(.socketProtocol) ?? "UDP")
qname  = to_string(.qname) ?? "."
if length(qname) > 1 && ends_with(qname, ".") {
    qname = slice!(qname, 0, length(qname) - 1)   # BIND prints qname without the root dot
}
qclass = .responseData.question[0].class
if qclass == null { qclass = .requestData.question[0].class }
qclass = to_string(qclass) ?? "IN"
qtype  = to_string(.qtype) ?? ""

if .rcode != null {   # only responses carry an rcode
    flags = "-"
    if .responseData.header.rd == true { flags = "+" }
    if .responseData.header.aa == true { flags = flags + "A" }
    if .responseData.header.tc == true { flags = flags + "T" }
    if .responseData.header.ad == true { flags = flags + "D" }
    rcode = upcase(to_string(.rcode) ?? "NOERROR")   # NoError -> NOERROR (BIND spelling)
    rrs = ""
    if is_array(.responseData.answers) {
        for_each(array!(.responseData.answers)) -> |_i, rr| {
            rrs = rrs + " " + (to_string(rr.domainName) ?? "") + " " + (to_string(rr.ttl) ?? "0") + " " + (to_string(rr.class) ?? "IN") + " " + (to_string(rr.recordType) ?? "") + " " + (to_string(rr.rData) ?? "") + ";"
        }
    }
    pid = to_string(.responseData.header.id) ?? "0"
    .message = syslog_ts + " " + host + " named[" + pid + "]: client " + client + "#" + cport + " (" + qname + "): " + proto + ": query: " + qname + " " + qclass + " " + qtype + " response: " + rcode + " " + flags + rrs
} else {
    flags = "-"
    if .requestData.header.rd == true { flags = "+" }
    pid = to_string(.requestData.header.id) ?? "0"
    .message = syslog_ts + " " + host + " named[" + pid + "]: client " + client + "#" + cport + " (" + qname + "): query: " + qname + " " + qclass + " " + qtype + " " + flags + " (" + server + ")"
}
'''

# ─────────────────────────────────────────────────────────────────────────────
# Transform: derive Prometheus metrics from the event stream.
# ─────────────────────────────────────────────────────────────────────────────
[transforms.dnstap_metrics]
type = "log_to_metric"
inputs = ["dnstap_enriched"]

[[transforms.dnstap_metrics.metrics]]
type = "counter"
field = "qname"           # one per event carrying a DNS question
# namespace + name compose the exported series, so use a bare name here to
# avoid a doubled prefix (namespace "dnstap" -> dnstap_queries_total).
name = "queries_total"
namespace = "dnstap"
tags.qtype = "{{ qtype }}"
# NOTE: no rcode tag here — rcode is null on ClientQuery events, which would
# drop/garble the series. rcode lives on the responses counter below.

[[transforms.dnstap_metrics.metrics]]
type = "counter"
field = "rcode"           # only ClientResponse events carry rcode
name = "responses_total"  # exported as dnstap_responses_total
namespace = "dnstap"
tags.rcode = "{{ rcode }}"

# ─────────────────────────────────────────────────────────────────────────────
# Sink: Prometheus scrape endpoint.
# ─────────────────────────────────────────────────────────────────────────────
[sinks.prom_exporter]
type = "prometheus_exporter"
# internal_metrics included so /metrics is never empty and exposes pipeline health.
inputs = ["dnstap_metrics", "internal_metrics"]
address = "$metrics_listen"
default_namespace = "dnstap"

# ─────────────────────────────────────────────────────────────────────────────
# Sink: local JSONL archive (lab forensics, offline replay).
# Set jsonl_path = "" in config.toml to disable; the renderer drops this block.
# ─────────────────────────────────────────────────────────────────────────────
$jsonl_sink_block

# ─────────────────────────────────────────────────────────────────────────────
# Sink: Splunk HEC. Only emitted if [splunk].enabled = true in config.toml.
# ─────────────────────────────────────────────────────────────────────────────
$splunk_sink_block

# ─────────────────────────────────────────────────────────────────────────────
# Sink: NIOS-style lines on disk for a Splunk Universal Forwarder to monitor —
# the route into an indexer that only exposes a splunktcp (S2S) input, where
# raw TCP/syslog text is silently discarded and HEC is unavailable.
# Only emitted if vector.nios_log_path is set in config.toml.
# ─────────────────────────────────────────────────────────────────────────────
$nios_file_sink_block

# ─────────────────────────────────────────────────────────────────────────────
# Sink: Grafana Loki — decoded events searchable in Grafana alongside metrics.
# (localhost default for a co-located observability stack; see install_loki.sh)
# ─────────────────────────────────────────────────────────────────────────────
[sinks.loki]
type = "loki"
inputs = ["dnstap_enriched"]
endpoint = "http://localhost:3100"
healthcheck.enabled = false
encoding.codec = "json"
labels.job = "dnstap"
labels.source = "infoblox"
labels.message_type = "{{ messageType }}"

# ─────────────────────────────────────────────────────────────────────────────
# Sink: syslog/SIEM forward (UDP) — NIOS-style query/response log lines, i.e.
# what a syslog collector would receive from InfoBlox itself. Repoint address
# at your collector (e.g. a Splunk syslog/UDP input).
# ─────────────────────────────────────────────────────────────────────────────
[sinks.syslog_out]
type = "socket"
inputs = ["dnstap_nios_syslog"]
mode = "udp"
address = "127.0.0.1:514"
encoding.codec = "text"
