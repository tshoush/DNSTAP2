# Copy to .env (gitignored) and set real values before `docker compose up`.
# docker compose auto-loads docker/stack/.env for ${VAR} interpolation.

# Splunk admin password — 8+ chars, not a common password (Splunk 9.x rejects weak ones).
SPLUNK_PASSWORD=changeme-8plus

# Splunk HEC token — any UUID; Vector uses the same value to send events.
# Generate one with: uuidgen
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
